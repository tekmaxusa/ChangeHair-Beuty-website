# MySQL on XAMPP, PHP app in Docker:
# -----------------------------------------------------------------
# 1. Create the DB with sql/xampp_db_user.sql + sql/schema.sql in XAMPP phpMyAdmin
#    (or sql/xampp_complete_setup.sql once).
# 2. Start the web container:
#      docker compose -f docker-compose.yml -f docker-compose.xampp-mysql.yml up -d --build --no-deps web
#
# DB_HOST/DB_PORT are set in docker-compose.xampp-mysql.yml (host.docker.internal:3306).
# Override here if you use different credentials:

DB_NAME=change_hair_beauty
DB_USER=salon_user
DB_PASS=salon_secret

WEB_PORT=8080

# Docker phpMyAdmin → XAMPP MySQL (docker-compose.xampp-phpmyadmin.yml)
# PMA_XAMPP_PORT=8082
