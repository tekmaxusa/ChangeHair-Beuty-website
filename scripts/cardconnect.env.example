# CardConnect / CardPointe — copy the block you need into changehair-api/.env (recommended).
# That file is what PHP loads for booking deposits and what scripts/_cardconnect_env.sh loads first.
#
# Optional: keep only CARDCONNECT_TEST_* in scripts/.env.cardconnect if you do not want test PAN/postal
# in the API env file; _cardconnect_env.sh merges it after changehair-api/.env.
#
# Do not commit real credentials.

CARDCONNECT_BASE_URL=https://fts.cardconnect.com
CARDCONNECT_MERCHID=
CARDCONNECT_API_USER=
CARDCONNECT_API_PASSWORD=

# Optional — scripts/cardconnect-test-ecommerce-auth.sh
# CARDCONNECT_TEST_AMOUNT=1.00
# CARDCONNECT_TEST_POSTAL=80124
# CARDCONNECT_TEST_NAME=Test User
# CARDCONNECT_TEST_ADDRESS=123 Test St
# CARDCONNECT_TEST_CITY=Denver
# CARDCONNECT_TEST_STATE=CO
# CARDCONNECT_TEST_COUNTRY=US

# Optional — scripts/cardconnect-gateway-reads.sh
# CARDCONNECT_TEST_RETREF=082930785638
# CARDCONNECT_TEST_ORDERID=chb-ecom-1774324037
# CARDCONNECT_SETTLESTAT_DATE=0323
# CARDCONNECT_SETTLESTAT_BATCHID=
# CARDCONNECT_FUNDING_DATE=0323
# CARDCONNECT_FUNDING_PAGE=1
# CARDCONNECT_FUNDING_LIMIT=50
