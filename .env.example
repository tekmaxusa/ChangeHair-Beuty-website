# =============================================================================
# Frontend / Vite (GitHub Pages build) — repo root
# Copy to `.env` for local `npm run dev` / `npm run build`.
# GitHub Actions: set VITE_API_URL in repo Secrets for Pages (see docs/DEPLOYMENT.md).
# PHP, MySQL, OAuth redirects, CHB_APP_PUBLIC_URL → api/.env (not here).
#
# Full stack on one domain (cPanel): see docs/CPANEL-FULL-DEPLOY.md
#
# Production UI (this site): https://tekmaxhosting.com/bookings/changehair/
# Build for cPanel with (example — use your real API URL):
#   VITE_BASE=/bookings/changehair/
#   VITE_API_URL=https://tekmaxhosting.com/bookings/changehair/public
# =============================================================================

# Public API base URL (no trailing slash) — where public/api/ is reachable in the browser.
VITE_API_URL=

# Base path for assets/router when the app is not at domain root (cPanel: /bookings/changehair/).
# VITE_BASE=/bookings/changehair/

# -----------------------------------------------------------------------------
# Optional — AI Studio / Gemini (only if you use that workflow)
# -----------------------------------------------------------------------------
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
