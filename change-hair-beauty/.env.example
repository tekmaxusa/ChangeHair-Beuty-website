WEB_PORT=8080
# Host port mapped from Docker MySQL (compose maps 3307→3306). Use 3307 from XAMPP/Windows PHP via DB_HOST=127.0.0.1.
DB_PORT=3307
DB_NAME=change_hair_beauty
DB_USER=salon_user
DB_PASS=salon_secret
DB_ROOT_PASSWORD=root_secret_change_me

# Optional — Google OAuth (“Continue with Google”)
# PHP reads this file automatically (see config/env.php) when vars are empty in the shell/Docker layer.
# Create an OAuth “Web application” client: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match EXACTLY what Google receives, e.g.:
#   http://localhost:8080/google-oauth-callback.php
#   https://yourdomain.com/google-oauth-callback.php
# If you use HTTPS in front (Cloudflare, nginx, etc.), either list the https URI in Google Console
# or set GOOGLE_REDIRECT_URI below explicitly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Contact form → PHP mail() (set on your server / Docker so messages are delivered)
# CONTACT_MAIL_TO overrides salon contact_email from config/salon_data.php
CONTACT_MAIL_TO=
# A mailbox your host allows as From (often noreply@yourdomain.com)
CONTACT_MAIL_FROM=

# Optional — same Google Apps Script web app as https://github.com/tekmaxusa/changehair-beauty (VITE_GOOGLE_SCRIPT_URL).
# When set, contact + dashboard booking POST name/email/phone/service/date/time like the reference site.
CHB_GOOGLE_SCRIPT_URL=
