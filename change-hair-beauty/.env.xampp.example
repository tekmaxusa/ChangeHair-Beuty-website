# XAMPP (PHP/Apache sa PC) + MySQL sa Docker lang
# ------------------------------------------------------------
# 1. Kopyahin bilang .env sa folder na ito:
#      copy .env.xampp.example .env     (PowerShell/CMD)
# 2. I-start ang database:
#      docker compose up db -d
#      o: .\scripts\start-docker-db.ps1
# 3. Sa XAMPP: DocumentRoot → change-hair-beauty\public (tingnan docker/xampp-vhost.conf.example)
# 4. OAuth redirect URI sa Google Console: dapat tumugma sa URL ng XAMPP (hal. http://localhost/...)

DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=change_hair_beauty
DB_USER=salon_user
DB_PASS=salon_secret
DB_ROOT_PASSWORD=root_secret_change_me

WEB_PORT=8080

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

CONTACT_MAIL_TO=
CONTACT_MAIL_FROM=

CHB_GOOGLE_SCRIPT_URL=
