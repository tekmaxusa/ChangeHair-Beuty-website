# XAMPP (PHP/Apache on PC) + MySQL in Docker only
# ------------------------------------------------------------
# 1. Copy to .env in this folder:
#      copy .env.xampp.example .env     (PowerShell/CMD)
# 2. Start database (+ Docker phpMyAdmin to browse tables):
#      docker compose up db phpmyadmin -d
#      or: .\scripts\start-docker-db.ps1
#    phpMyAdmin: http://127.0.0.1:8081 — server: db (default), user: salon_user / pass: salon_secret
#    XAMPP phpMyAdmin: connect to 127.0.0.1 port 3307 (skip XAMPP MySQL if you want a single DB only)
# 3. In XAMPP: DocumentRoot → change-hair-beauty\public (see docker/xampp-vhost.conf.example)
# 4. OAuth redirect URI in Google Console must match your XAMPP URL (e.g. http://localhost/...)

DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=change_hair_beauty
DB_USER=salon_user
DB_PASS=salon_secret
DB_ROOT_PASSWORD=root_secret_change_me

WEB_PORT=8080
PMA_PORT=8081

ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

CONTACT_MAIL_TO=
CONTACT_MAIL_FROM=

CHB_GOOGLE_SCRIPT_URL=
