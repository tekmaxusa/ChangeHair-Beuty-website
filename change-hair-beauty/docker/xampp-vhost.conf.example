# Example for XAMPP Apache (Windows)
# ------------------------------------------------------------
# 1. Replace Y:/path/to/... with your real repo path (folder that contains public/).
# 2. Include from httpd.conf:
#      Include conf/extra/httpd-vhosts.conf
# 3. Add this block to C:\xampp\apache\conf\extra\httpd-vhosts.conf
#    (or copy this file and Include it from httpd.conf).
# 4. In C:\xampp\apache\conf\httpd.conf ensure this is enabled:
#      LoadModule rewrite_module modules/mod_rewrite.so
# 5. Open: http://changehair.local/  (add to C:\Windows\System32\drivers\etc\hosts:
#      127.0.0.1  changehair.local)

<VirtualHost *:80>
    ServerName changehair.local
    DocumentRoot "Y:/path/to/Pika-Pika-main/change-hair-beauty/public"

    <Directory "Y:/path/to/Pika-Pika-main/change-hair-beauty/public">
        Options Indexes FollowSymLinks
        AllowOverride All
        Require all granted
    </Directory>

    ErrorLog "logs/changehair-error.log"
    CustomLog "logs/changehair-access.log" common
</VirtualHost>
