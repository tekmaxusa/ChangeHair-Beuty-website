# Copy to `.cpanel-deploy.env` (gitignored) and set host, user, and SSH key path.
# Used by `scripts/deploy-cpanel.sh` and `scripts/push-and-deploy-api.sh` (source'd automatically).

# Example host (this site): tekmaxhosting.com
export CPANEL_SSH_HOST=tekmaxhosting.com
export CPANEL_SSH_USER=your_cpanel_user
export CPANEL_SSH_IDENTITY_FILE="$PWD/cpanel_deploy_key"

# Single folder on the server: Vite output (dist/) and the PHP API tree (api/) both rsync here.
# Defaults match deploy-cpanel.sh — set only if you need a different path.
export FRONTEND_REMOTE_PATH=public_html/bookings/changehair
export API_REMOTE_PATH=public_html/bookings/changehair
